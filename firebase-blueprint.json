{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "blocked": { "type": "boolean", "description": "Whether the user is blocked" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Digital VPN product",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "VPN name" },
        "price": { "type": "number", "description": "Price in BDT" },
        "category": { "type": "string", "description": "Product category" },
        "image": { "type": "string", "description": "Product image URL" },
        "description": { "type": "string", "description": "Product description" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Product creation timestamp" }
      },
      "required": ["name", "price", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "Purchase order for digital products",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the buyer" },
        "userEmail": { "type": "string", "description": "Email of the buyer" },
        "items": { "type": "array", "description": "List of purchased items" },
        "total": { "type": "number", "description": "Total price in BDT" },
        "paymentMethod": { "type": "string", "description": "bKash or Nagad" },
        "transactionId": { "type": "string", "description": "Payment transaction ID" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Order status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order placement timestamp" },
        "credentials": { "type": "object", "description": "Generated VPN credentials" }
      },
      "required": ["userId", "items", "total", "transactionId", "status"]
    },
    "SupportMessage": {
      "title": "SupportMessage",
      "description": "Customer support message",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user" },
        "userEmail": { "type": "string", "description": "Email of the user" },
        "message": { "type": "string", "description": "Message content" },
        "status": { "type": "string", "enum": ["unread", "read"], "description": "Message status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Message timestamp" }
      },
      "required": ["userEmail", "message", "status"]
    },
    "PaymentConfig": {
      "title": "PaymentConfig",
      "description": "Payment numbers for bKash and Nagad",
      "type": "object",
      "properties": {
        "bKash": { "type": "string", "description": "bKash number" },
        "Nagad": { "type": "string", "description": "Nagad number" }
      },
      "required": ["bKash", "Nagad"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "VPN products"
    },
    "/support_messages/{messageId}": {
      "schema": "SupportMessage",
      "description": "Customer support messages"
    },
    "/config/payments": {
      "schema": "PaymentConfig",
      "description": "Payment configuration"
    }
  }
}
